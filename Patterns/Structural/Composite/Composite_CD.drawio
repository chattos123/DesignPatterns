        <mxCell id="ANI1TH_7SKkldHsHBK8A-28" value="for each IComponent" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="1" vertex="1">
          <mxGeometry x="670" y="420" width="60" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ANI1TH_7SKkldHsHBK8A-29" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;br&gt;&lt;/h1&gt;&lt;p&gt;represents leaf objects in the composition. A leaf has no children.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;defines behavior for primitive objects in the composition.&lt;/span&gt;.&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;However there is LSP violation&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="30" y="400" width="190" height="200" as="geometry" />
        </mxCell>
        <mxCell id="ANI1TH_7SKkldHsHBK8A-30" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;br&gt;&lt;/h1&gt;&lt;p&gt;defines behavior for components having children.&lt;/p&gt;&lt;p&gt;stores child components.&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;implements child-related operations in the Component interface&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="360" y="398" width="180" height="172" as="geometry" />
        </mxCell>
        <mxCell id="ANI1TH_7SKkldHsHBK8A-31" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;br&gt;&lt;/h1&gt;&lt;p&gt;manipulates objects in the composition through the Component interface&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="-40" y="170" width="170" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ANI1TH_7SKkldHsHBK8A-32" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;&lt;br&gt;&lt;/h1&gt;&lt;p&gt;declares the interface for objects in the composition.&lt;/p&gt;&lt;p&gt;implements default behavior for the interface common to all classes, as appropriate.&lt;/p&gt;&lt;p&gt;declares an interface for accessing and managing its child components.&lt;/p&gt;&lt;p&gt;(optional) defines an interface for accessing a component&#39;s parent in the recursive structure, and implements it if that&#39;s appropriate&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="300" y="-150" width="180" height="272" as="geometry" />
        </mxCell>
        <mxCell id="ANI1TH_7SKkldHsHBK8A-33" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Composite Pattern&lt;/h1&gt;&lt;p&gt;The Composite design pattern composes objects into tree structures to represent part-whole hierarchies. This pattern lets clients treat individual objects and compositions of objects uniformly&lt;/p&gt;" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fillColor=#dae8fc;strokeColor=#6c8ebf;" parent="1" vertex="1">
          <mxGeometry x="-40" y="-130" width="280" height="190" as="geometry" />
        </mxCell>
